# 应用配置
APP_NAME="AI Stock Assistant API"
API_V1_STR="/api/v1"

# 端口配置（如果有冲突可以修改）
# 修改后需要重新启动: docker-compose down && docker-compose up -d
BACKEND_PORT=8888      # 后端API端口
FRONTEND_PORT=8889     # 前端端口
REDIS_PORT=6379        # Redis端口（一般不用改）

# 数据源配置
# 可选值: "alphavantage", "tushare", "akshare"
DEFAULT_DATA_SOURCE="akshare"

# Alpha Vantage API配置（美股数据，可选）
# 免费版限制：每天25次调用
ALPHAVANTAGE_API_BASE_URL="https://www.alphavantage.co/query"
ALPHAVANTAGE_API_KEY="NZ3ITU8KIFS7BV6H"

# Tushare API配置
TUSHARE_API_TOKEN="your_tushare_api_token"

# AKShare配置
AKSHARE_USE_PROXY=False
AKSHARE_PROXY_URL=""

# 雪球配置（用于AKShare的部分接口）
# 无需手动填写，程序会自动获取和更新
XUEQIU_TOKEN="your_xueqiu_token"

# 数据库配置
DATABASE_URL="sqlite:///./stock_assistant.db"

# 安全配置（重要！必须修改！）
# JWT 密钥 - 用于签名和验证用户登录 token
# 生成强密钥命令: openssl rand -hex 32
SECRET_KEY="bca9b4fd441bcac792159373326ac032ea30fab4615c92e404e7200479242df9"

# AI分析配置
# 可选值: "rule", "ml", "llm"
DEFAULT_ANALYSIS_MODE="llm"

# AI模型配置
AI_MODEL_PATH="./models/stock_analysis_model.pkl"

# LLM 配置（LiteLLM 统一接口）https://docs.litellm.ai/docs/provider
# 模型格式：provider/model_name，如 openai/gpt-4o-mini、deepseek/deepseek-chat、anthropic/claude-3-5-sonnet
LLM_MODEL="zai/glm-4.7"
ZAI_API_KEY="a52846efee7e45cb8c0f422d8c3d0250.sw0UZdNj9jXbIA7M"
LLM_API_BASE="https://open.bigmodel.cn/api/paas/v4"
LLM_MAX_TOKENS=5000
LLM_TEMPERATURE=0.1
# 可选：逗号分隔的可用模型列表，供前端切换
LLM_AVAILABLE_MODELS=zai/glm-4.7
# 向量检索 / 长期记忆配置（Chroma + Embedding）
# 默认使用 OpenAI 兼容 embedding
EMBEDDING_MODEL="embedding-3"
# 可选：单独为向量检索配置 provider，不填则回退到 LLM_API_BASE / LLM_API_KEY
EMBEDDING_API_BASE="https://open.bigmodel.cn/api/paas/v4/embeddings"
EMBEDDING_API_KEY="69881c4f7bf84b649ccaf0d7ca0ab799.7LBsy6XKkqt6M2tr"

# 可选：为不同角色指定专用模型（未配置则回退到上面的 LLM_*）
# LLM_DEFAULT_MODEL="openai/gpt-4o-mini"
# LLM_RESEARCH_MODEL="openai/gpt-4o-mini"
# LLM_RISK_MODEL="openai/gpt-4o-mini"

# CORS配置（跨域资源共享）
# 本地开发: http://localhost:8889,http://localhost:8889
# 生产环境: 只配置你的实际域名，不要包含 *
# 多个域名用逗号分隔，不要加空格
CORS_ORIGINS=http://localhost:8889,http://localhost:8888,http://frontend:3000,http://backend:8000

# 管理员账户配置（首次启动时自动创建）
# 建议修改默认密码！
ADMIN_USERNAME="Peter Xue"
ADMIN_EMAIL="evankingse@gmail.com"
ADMIN_PASSWORD="XHY20040219xx!"

# Redis和Celery配置
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0 

# 搜索引擎配置（2000积分可用）
# 可选值：serpapi, googleapi, bingapi
# SEARCH_API_ENABLED=True
# SEARCH_ENGINE=serpapi
# SERPAPI_API_KEY=你的SerpAPI密钥