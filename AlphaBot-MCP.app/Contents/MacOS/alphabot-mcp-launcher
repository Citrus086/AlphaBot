#!/bin/bash

# AlphaBot + MCP 启动器 for macOS
# 这个脚本会在终端中运行启动脚本，并保持窗口打开

APP_NAME="AlphaBot with MCP"

# 方法1: 从脚本路径计算（当作为脚本直接运行时）
SCRIPT_DIR=""
if [ -n "${BASH_SOURCE[0]}" ]; then
    SCRIPT_SOURCE="${BASH_SOURCE[0]}"
    # 如果是相对路径，转换为绝对路径
    if [[ "$SCRIPT_SOURCE" != /* ]]; then
        SCRIPT_SOURCE="$(pwd)/$SCRIPT_SOURCE"
    fi
    # 计算项目根目录: <PROJECT>/AlphaBot-MCP.app/Contents/MacOS/this-script -> 上3层
    PROJECT_DIR_GUESS="$(cd "$(dirname "$SCRIPT_SOURCE")/../../.." 2>/dev/null && pwd)"
    if [ -f "$PROJECT_DIR_GUESS/start-with-mcp.sh" ]; then
        SCRIPT_DIR="$PROJECT_DIR_GUESS"
    fi
fi

# 方法2: 从当前工作目录（当通过 .app 双击运行时，工作目录是 .app/Contents/MacOS/）
if [ -z "$SCRIPT_DIR" ]; then
    CWD="$(pwd)"
    # 检查是否在 .app/Contents/MacOS 目录
    if [[ "$CWD" == */AlphaBot-MCP.app/Contents/MacOS ]]; then
        SCRIPT_DIR="$(cd "$CWD/../../.." && pwd)"
    fi
fi

# 方法3: 查找上级的 start-with-mcp.sh
if [ -z "$SCRIPT_DIR" ]; then
    # 向上查找4层（从 .app/Contents/MacOS 开始）
    for parent in .. ../.. ../../.. ../../../..; do
        if [ -f "$(cd "$parent" 2>/dev/null && pwd)/start-with-mcp.sh" ]; then
            SCRIPT_DIR="$(cd "$parent" && pwd)"
            break
        fi
    done
fi

# 最终检查
if [ -z "$SCRIPT_DIR" ] || [ ! -f "$SCRIPT_DIR/start-with-mcp.sh" ]; then
    osascript -e "display dialog \"无法找到 AlphaBot 项目目录。\n\n请确保 AlphaBot-MCP.app 位于项目根目录内。\" buttons {\"确定\"} default button \"确定\" with icon stop"
    exit 1
fi

SCRIPT_PATH="$SCRIPT_DIR/start-with-mcp.sh"

# 从 .env 读取端口
FRONTEND_PORT=8889
BACKEND_PORT=8888
if [ -f "$SCRIPT_DIR/.env" ]; then
    eval $(grep -E "^(BACKEND_PORT|FRONTEND_PORT)=" "$SCRIPT_DIR/.env" 2>/dev/null)
fi

# 构建提示信息
COMPLETION_MSG="启动完成！如果浏览器没有自动打开，请访问:
前端: http://localhost:$FRONTEND_PORT
API文档: http://localhost:$BACKEND_PORT/api/v1/docs

按回车键关闭此窗口..."

# 启动终端并保持打开
osascript <<EOF
tell application "Terminal"
    activate
    set windowId to do script "cd '$SCRIPT_DIR' && ./start-with-mcp.sh start; echo ''; echo '========================================'; echo '$COMPLETION_MSG'; read"
    set custom title of front window to "AlphaBot + MCP 启动中..."
end tell
EOF

# 显示通知
osascript -e "display notification \"正在后台启动 AlphaBot 和 MCP，请查看终端窗口\" with title \"$APP_NAME\""
