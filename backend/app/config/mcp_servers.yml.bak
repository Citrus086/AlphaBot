# MCP servers configuration (AlphaBot as MCP host)
#
# Each entry describes one MCP server that exposes a JSON-RPC HTTP endpoint
# implementing at least:
# - "tools/list"
# - "tools/call"
#
# Example (uncomment and adjust to use):
#
# servers:
#   - id: trendradar
#     base_url: ${TRENDRADAR_MCP_HTTP_URL}   # e.g. http://localhost:4210
#     api_key: ${TRENDRADAR_MCP_API_KEY}     # optional, if the server requires auth
#
servers: 
  # mcporter-bridge - 本地 MCP 工具桥接
  # 使用宿主机 IP 让 Docker 容器访问
  # FastMCP 3.x HTTP transport 端点是 /mcp
  - id: mcporter_bridge
    base_url: http://192.168.0.102:8765/mcp
    # api_key: 如果需要认证再填

  # 其他 MCP 服务器（可选）
  # - id: trendradar
  #   base_url: ${TRENDRADAR_MCP_HTTP_URL}
  #   api_key: ${TRENDRADAR_MCP_API_KEY}

